        "dirty scrap paper",
        "yellowed old paper",
        "long handwritten body",
        "制作说明"
      ],
      "forbidden_positive_terms": [
        "人物",
        "person",
        "human",
        "火柴人",
        "stick figure",
        "完整场景",
