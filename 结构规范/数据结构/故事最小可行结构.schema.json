{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "故事最小可行结构",
  "type": "object",
  "required": [
    "story_id",
    "protagonist",
    "threat",
    "rule",
    "pages",
    "pass"
  ],
  "properties": {
    "story_id": {
      "type": "string"
    },
    "protagonist": {
      "type": "string"
    },
    "threat": {
      "type": "string"
    },
    "rule": {
      "type": "string"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 2
    },
    "pages": {
      "type": "array",
      "minItems": 6,
      "maxItems": 8,
      "items": {
        "type": "object"
      }
    },
    "pass": {
      "type": "boolean"
    }
  }
}
